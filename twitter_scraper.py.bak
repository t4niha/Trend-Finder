import asyncio
import json
from pathlib import Path

from twscrape import API

TOPIC = "Artificial Intelligence"
TARGET = 500
BATCH_SIZE = 50
OUTPUT_PATH = Path("data/twitter.json")


def format_error(err: Exception) -> str:
    msg = str(err)
    low = msg.lower()
    if "rate" in low and "limit" in low:
        return f"Rate Limit reached: {msg}"
    if "lock" in low:
        return f"Account Locked: {msg}"
    if "timeout" in low:
        return f"Connection Timeout: {msg}"
    return f"Unexpected error: {msg}"


async def collect_tweets():
    api = API()

    tweets = []
    count = 0

    try:
        async for t in api.search(TOPIC, limit=TARGET):
            record = {
                "id": t.id,
                "text": getattr(t, "rawContent", getattr(t, "content", "")),
                "timestamp": t.date.isoformat() if getattr(t, "date", None) else None,
                "username": t.user.username if getattr(t, "user", None) else None,
                "likes": getattr(t, "likeCount", getattr(getattr(t, "stats", None) or {}, "get", lambda _k: None)("likeCount")),
                "retweets": getattr(t, "retweetCount", getattr(getattr(t, "stats", None) or {}, "get", lambda _k: None)("retweetCount")),
            }
            tweets.append(record)
            count += 1

            if count % BATCH_SIZE == 0:
                print(f"Collected {count}/{TARGET}...")
                await asyncio.sleep(5)

        print("Collection complete, saving to data/twitter.json")
        OUTPUT_PATH.parent.mkdir(parents=True, exist_ok=True)
        OUTPUT_PATH.write_text(json.dumps(tweets, ensure_ascii=False, indent=2), encoding="utf-8")
        print(f"Saved {len(tweets)} tweets to {OUTPUT_PATH}")

    except Exception as err:
        print(format_error(err))


if __name__ == "__main__":
    asyncio.run(collect_tweets())
